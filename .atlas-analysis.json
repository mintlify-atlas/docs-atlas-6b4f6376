  "keyFeatures": [
    "Hardware-accelerated anti-aliased vector graphics",
    "HTML5 Canvas-style API for paths, shapes, and curves",
    "Multiple rendering backends: OpenTK, Raylib, SFML, Silk.NET, Unity, WebAssembly",
    "Linear, radial, and box gradient brushes",
    "Full text rendering with font atlas and HiDPI support",
    "Rich text with animations (wave, shake, typewriter, rainbow effects)",
    "Markdown rendering with image and link support",
    "SVG parsing and rendering",
    "3D-to-2D projection canvas wrapper (Canvas3D)",
    "Scissor clipping with transform support",
    "Customizable stroke styles: caps (Butt, Round, Square), joins (Miter, Round, Bevel), dash patterns",
    "Custom shader and uniform support per draw call",
    "Backdrop blur (frosted glass) effect",
    "State stack (SaveState/RestoreState)",
    "Efficient draw call batching"
  ],
